{
  "name": "grabitt",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter server run db:generate",
    "db:migrate": "pnpm --filter server run db:migrate",
    "db:studio": "pnpm --filter server run db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.31"
    }
  }
}
