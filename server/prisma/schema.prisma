// Grabitt v2 — Prisma Schema
// Every monetary calculation uses server-side values only.
// Never trust client-sent fee or net amounts. (§10.2)

generator client {
  provider      = "prisma-client-js"
  // native = local dev; rhel = Vercel serverless (Amazon Linux 2 / RHEL)
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Users ──────────────────────────────────────────────────────────────────

enum UserGrade {
  grabber
  dealer
  trader
  pro
}

// Paid recurring plans (Stripe Billing). Prices/intervals live in
// packages/design-tokens SUBSCRIPTION_PLANS — the source of truth.
enum SubPlan {
  business      // €29/mo, 21-day trial — storefront, badge, instant Dealer
  service_ad    // €29/mo — advertise a service (tradespeople)
  page_banner   // €39/mo — banner across Grabitt pages
  directory     // €99/yr — business directory listing
}

enum SubStatus {
  trialing
  active
  past_due
  canceled
  paused
}

// ── Homepage CMS (section layout) ─────────────────────────────────────────────
// Admin-controlled homepage blocks: which sections show and in what order.
model HomeSection {
  id        String  @id @default(uuid())
  key       String  @unique
  label     String
  enabled   Boolean @default(true)
  sortOrder Int

  @@index([sortOrder])
}

// Parallax hero slider — a set of slides (image + heading + link), NOT banners.
model HeroSlide {
  id         String   @id @default(uuid())
  heading    String?
  subheading String?
  imageUrl   String
  linkUrl    String?
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([sortOrder])
}

// ── Community content ─────────────────────────────────────────────────────────
// Editorial posts (island tips, economy write-ups, how-to guides) surfaced on the
// homepage. Admin-managed; readers just view them.
model CommunityPost {
  id         String   @id @default(uuid())
  title      String
  excerpt    String                       // short teaser shown on the strip
  body       String                       // full article (markdown-ish plain text)
  category   String   @default("Guide")   // e.g. Guide, Island Tips, Economy, Selling
  emoji      String   @default("📰")
  imageUrl   String?
  published  Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published])
  @@index([sortOrder])
}

// ── Compliance / GDPR ─────────────────────────────────────────────────────────
enum ConsentKind {
  gdpr                // GDPR data-processing acceptance
  withdrawal_waiver   // EU right-to-withdraw exemption disclaimer (digital marketplace)
}

// Immutable audit trail of consent acceptances (proof of when + who accepted).
model Consent {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  kind        ConsentKind
  version     String      @default("1")
  // Immutable snapshot of who accepted — survives later GDPR anonymisation,
  // so the waiver record stands if a user later disputes it.
  email       String
  displayName String
  acceptedAt  DateTime    @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([userId])
  @@index([kind])
}

enum DeletionStatus {
  requested
  completed
}

// GDPR erasure requests — recorded even after the account PII is cleared.
model DeletionRequest {
  id          String         @id @default(uuid())
  userId      String         // kept as a reference; the User row is anonymised, not deleted
  email       String         // email at time of request (for the audit record)
  displayName String
  status      DeletionStatus @default(requested)
  requestedAt DateTime       @default(now())
  completedAt DateTime?

  @@index([status])
  @@index([requestedAt])
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  plan                 SubPlan
  status               SubStatus
  stripeSubscriptionId String    @unique
  stripeCustomerId     String
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
}

enum Locale {
  en
  es
  de
  da
  sv
  nl
  fr
  pt
}

model User {
  id                 String    @id @default(uuid())
  supabaseId         String    @unique
  email              String    @unique
  displayName        String
  avatar             String?
  phone              String?   // contact number, shared with a buyer only after a completed collection sale
  collectionAddress  String?   // collection address, shared with a buyer only after a completed collection sale
  grade              UserGrade @default(grabber)
  salesCount         Int       @default(0)
  avgRating          Float?
  credits            Int       @default(50)
  isBusiness         Boolean   @default(false)
  businessVerified   Boolean   @default(false)
  businessTrialEnds  DateTime?
  businessName       String?
  businessBio        String?
  businessBanner     String?

  // Compliance (GDPR consent + EU right-to-withdraw waiver + erasure)
  gdprAcceptedAt            DateTime?
  withdrawalWaiverAcceptedAt DateTime?
  deletedAt                 DateTime?  // GDPR erasure: PII cleared, access revoked, records kept
  stripeAccountId    String?
  stripeCustomerId   String?
  locale             Locale    @default(en)

  // Verification
  isVerified         Boolean   @default(false)
  emailVerified      Boolean   @default(false)
  phoneVerified      Boolean   @default(false)
  idVerified         Boolean   @default(false)
  addressVerified    Boolean   @default(false)
  // ID / address docs awaiting manual review: 'none' | 'pending'. Approval flips
  // idVerified/addressVerified via the exec member admin. The doc itself lives in
  // a private bucket; the path is served only to the owner/admin via signed URL.
  idDocStatus        String    @default("none")
  addressDocStatus   String    @default("none")
  idDocPath          String?
  addressDocPath     String?
  // Phone OTP (hashed code + expiry); cleared once verified.
  phoneOtpHash       String?
  phoneOtpExpiresAt  DateTime?

  // Referral: each user has a shareable code; referredBy links to whoever's code
  // they signed up with. referralRewarded guards the one-time "first listing"
  // bonus so both parties are credited exactly once.
  referralCode       String?   @unique
  referredById       String?
  referredBy         User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]    @relation("Referrals")
  referralRewarded   Boolean   @default(false)

  // Moderation
  strikeCount        Int       @default(0)
  suspendedAt        DateTime?
  suspendedUntil     DateTime?
  suspendedReason    String?

  // Snowbird mode — member marks themselves away
  snowbirdMode       Boolean   @default(false)
  snowbirdUntil      DateTime?
  // Marketing email: consent is the GDPR lawful basis, so campaigns may only go
  // to marketingConsent = true. The token powers one-click unsubscribe.
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?
  unsubscribeToken   String    @unique @default(uuid())

  // Department interests used for personalisation & alerts
  interests          String[]  @default([])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  listings           Listing[]
  cartItems          CartItem[]
  buyerTransactions  Transaction[]      @relation("Buyer")
  sellerTransactions Transaction[]      @relation("Seller")
  sentMessages       Message[]
  threads            ThreadParticipant[]
  notifications      Notification[]
  creditEvents       CreditEvent[]
  wishlistItems      WishlistItem[]
  wishItems          WishItem[]
  savedSearches      SavedSearch[]
  reviews            Review[]           @relation("ReviewAuthor")
  receivedReviews    Review[]           @relation("ReviewSubject")
  disputes           Dispute[]          @relation("DisputeRaiser")
  crmContacts        CrmContact[]       @relation("CrmAssigned")
  handyListings      HandyListing[]
  following          Following[]        @relation("Follower")
  followers          Following[]        @relation("Following")
  pushTokens         PushToken[]
  reportsFiled       Report[]           @relation("Reporter")
  reportsAgainst     Report[]           @relation("ReportedUser")
  jobApplications    JobApplication[]
  strikes            UserStrike[]
  execAuditLogs      ExecAuditLog[]     @relation("ExecTarget")
  subscriptions      Subscription[]
  consents           Consent[]
  seekerProfile      SeekerProfile?
  candidateUnlocks   CandidateUnlock[]  @relation("EmployerUnlocks")
  unlockedBy         CandidateUnlock[]  @relation("SeekerUnlocked")
  eshotRecipients    EshotRecipient[]

  @@index([grade])
  @@index([email])
}

// A job-seeker's "available for work" profile. Employers search these anonymously
// via Find Staff and spend credits to unlock the person's contact details.
model SeekerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  headline         String?
  sector           String?
  roles            String[] @default([])
  experienceMonths Int      @default(0)
  languages        String[] @default([])
  hours            String[] @default([])
  availability     String?
  rightToWork      String?
  location         String?
  active           Boolean  @default(true)
  // ── CV content — the candidate's real CV, entered structured and rendered to
  // a formatted PDF on apply. Repeatable sections are JSON arrays:
  //   workExperience: [{ title, employer, location, start, end, current, bullets[] }]
  //   education:      [{ qualification, institution, start, end, status }]
  summary          String?
  skills           String[] @default([])
  keyStrengths     String[] @default([])
  certifications   String[] @default([])
  workExperience   Json?
  education        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([active])
  @@index([sector])
}

// Records that an employer has paid credits to reveal a seeker — so re-viewing
// an already-unlocked candidate is free (idempotent unlock).
model CandidateUnlock {
  id         String   @id @default(uuid())
  employerId String
  employer   User     @relation("EmployerUnlocks", fields: [employerId], references: [id])
  seekerId   String
  seeker     User     @relation("SeekerUnlocked", fields: [seekerId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([employerId, seekerId])
  @@index([employerId])
}

model ExecUser {
  id           String         @id @default(uuid())
  email        String         @unique
  role         ExecRole
  createdAt    DateTime       @default(now())

  auditLogs    ExecAuditLog[]
  tasks        ExecTask[]
}

// Internal exec to-do / calendar item. One model serves both views: the To-Do
// board groups by `tier`, the Calendar places items by `dueDate`. Scoped to the
// exec who created it so each admin has their own list.
model ExecTask {
  id         String    @id @default(uuid())
  execUserId String
  execUser   ExecUser  @relation(fields: [execUserId], references: [id])
  text       String
  tier       String?   // 'urgent' | 'soon' | 'someday' (To-Do)
  dueDate    DateTime? @db.Date // (Calendar)
  color      String?   // dot colour on the calendar
  done       Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([execUserId])
}

enum ExecRole {
  super_admin
  admin
  support
}

// ── Listings ────────────────────────────────────────────────────────────────

enum Department {
  home_garden
  jobs
  fashion
  sport
  gaming
  electronics
  gift_ideas
  kids_baby
  property
  health_fitness
  food_store
  retro_vintage
  grab_it_now
  handy_help
  pet_shop
  motors
  services
  collectables
  hobbies_crafts
  other
}

enum ListingCondition {
  new
  like_new
  very_good
  good
  fair
  spares
}

enum ListingStatus {
  draft
  active
  grab_it_now
  sold
  expired
  removed
}

model Listing {
  id               String           @id @default(uuid())
  sellerId         String
  seller           User             @relation(fields: [sellerId], references: [id])
  title            String
  description      String
  price            Decimal          @db.Decimal(10, 2)
  department       Department
  condition        ListingCondition
  // Item facts shown in the listing's Details panel (all optional — blank ones
  // render as "—", exactly as the template does).
  brand            String?
  colour           String?
  size             String?
  status           ListingStatus    @default(draft)
  images           String[]
  tags             String[]         @default([])  // auto-generated from title/description for search + discovery
  stock            Int              @default(1)    // units available; sold when it reaches 0 (multi-buy)
  location         String
  lat              Float?
  lng              Float?
  isFeatured       Boolean          @default(false)
  featuredUntil    DateTime?
  grabItNowUntil   DateTime?
  grabItNowWindow  Int?
  grabItNowPrice   Decimal?         @db.Decimal(10, 2)
  deliveryFee      Decimal          @default(0) @db.Decimal(10, 2)
  deliveryMethod   DeliveryMethod?  // null = delivery not offered (collection only)
  autoAcceptMin    Decimal?         @db.Decimal(10, 2)  // offers >= this are auto-accepted (seller-only, never shown to buyers)
  viewCount        Int              @default(0)
  relistCount      Int              @default(0)  // standard listings auto-relist free 3× every 21 days
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  transactions     Transaction[]
  jobListing       JobListing?
  propertyListing  PropertyListing?
  handyListing     HandyListing?
  wishlistItems    WishlistItem[]
  cartItems        CartItem[]
  reports          Report[]
  offers           Offer[]

  @@index([department])
  @@index([status])
  @@index([sellerId])
  @@index([isFeatured])
  @@index([createdAt(sort: Desc)])
  @@index([location])
}

// ── Transactions ─────────────────────────────────────────────────────────────

enum TransactionStatus {
  pending_payment
  held
  confirmed_handover
  completed
  released
  disputed
  refunded
  cancelled
}

enum FulfilmentType {
  collection   // buyer collects in person — released via QR handover scan
  courier      // shipped by tracked courier — released on first waypoint scan (in transit)
  delivery     // seller delivers in person (charged) — released via QR handover scan
}

// How a seller fulfils delivery when they offer it on a listing
enum DeliveryMethod {
  courier      // tracked shipping
  in_person    // seller drops off, confirmed by QR at the door
}

model Transaction {
  id                    String            @id @default(uuid())
  listingId             String
  listing               Listing           @relation(fields: [listingId], references: [id])
  buyerId               String
  buyer                 User              @relation("Buyer", fields: [buyerId], references: [id])
  sellerId              String
  seller                User              @relation("Seller", fields: [sellerId], references: [id])
  amount                Decimal           @db.Decimal(10, 2)
  platformFee           Decimal           @db.Decimal(10, 2)
  sellerNet             Decimal           @db.Decimal(10, 2)
  status                TransactionStatus @default(pending_payment)
  quantity              Int               @default(1)
  fulfilmentType        FulfilmentType    @default(collection)
  stripePaymentIntentId String?
  stripeTransferId      String?
  handoverQrToken       String?           // signed token for QR handover confirmation
  handoverConfirmedAt   DateTime?
  trackingCarrier       String?           // courier fulfilment: carrier name/slug
  trackingNumber        String?           // courier fulfilment: tracking number (tracked service required)
  firstScanAt           DateTime?         // legacy: kept for historical orders
  shippedAt             DateTime?         // courier: dispatched / first carrier scan
  deliveredAt           DateTime?         // courier: delivery confirmed → starts both timers below
  disputeWindowEndsAt   DateTime?         // deliveredAt + 24h; after this the item is deemed accepted
  fundsReleasedAt       DateTime?
  // Collection: handoverConfirmedAt + 14 days. Courier: deliveredAt + 48 hours.
  autoReleaseAt         DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  dispute               Dispute?
  reviews               Review[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([autoReleaseAt])
  @@index([listingId])
}

// ── Messaging ────────────────────────────────────────────────────────────────

enum MessageChannel {
  in_app
  sms
  whatsapp
}

model Thread {
  id            String             @id @default(uuid())
  listingId     String
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())

  participants  ThreadParticipant[]
  messages      Message[]

  @@index([listingId])
  @@index([lastMessageAt(sort: Desc)])
}

model ThreadParticipant {
  threadId String
  userId   String
  thread   Thread @relation(fields: [threadId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@id([threadId, userId])
}

model Message {
  id            String         @id @default(uuid())
  threadId      String
  thread        Thread         @relation(fields: [threadId], references: [id])
  senderId      String
  sender        User           @relation(fields: [senderId], references: [id])
  body          String
  channel       MessageChannel @default(in_app)
  blocked       Boolean        @default(false)
  blockedReason String?        // populated when contact-info regex fires (§10.2)
  readAt        DateTime?
  createdAt     DateTime       @default(now())

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}

// ── Notifications ─────────────────────────────────────────────────────────────

enum NotificationKind {
  new_message
  offer_received
  offer_accepted
  offer_declined
  offer_countered
  payment_held
  handover_confirmed
  funds_released
  new_review
  listing_expiring
  grade_upgrade
  credits_received
  dispute_opened
  dispute_resolved
  wish_matched
  price_drop
  system
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  kind      NotificationKind
  title     String
  body      String
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt(sort: Desc)])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String   // "ios" | "android"
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Offers ──────────────────────────────────────────────────────────────────

enum OfferStatus {
  pending
  accepted
  declined
  countered
  expired
  withdrawn
}

model Offer {
  id        String      @id @default(uuid())
  listingId String
  listing   Listing     @relation(fields: [listingId], references: [id])
  buyerId   String
  amount    Decimal     @db.Decimal(10, 2)
  message   String?
  status    OfferStatus @default(pending)
  counterAmount Decimal? @db.Decimal(10, 2)  // seller's (auto) counter price
  counterTier   Int      @default(0)         // auto counter ladder: 0=none, 1/2/3 (3=final=min)
  expiresAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

// Server-side basket. Items expire 12h after being added; warnings fire at 6h/10h.
model CartItem {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId    String
  listing      Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  qty          Int       @default(1)
  warn6SentAt  DateTime?
  warn10SentAt DateTime?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime

  @@unique([userId, listingId])
  @@index([userId])
  @@index([expiresAt])
}

// ── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id                  String      @id @default(uuid())
  transactionId       String
  transaction         Transaction @relation(fields: [transactionId], references: [id])
  authorId            String
  author              User        @relation("ReviewAuthor", fields: [authorId], references: [id])
  subjectId           String
  subject             User        @relation("ReviewSubject", fields: [subjectId], references: [id])
  rating              Int         // overall 1–5
  accuracyRating      Int?        // item as described 1–5
  communicationRating Int?        // seller responsiveness 1–5
  speedRating         Int?        // handover speed 1–5
  comment             String?
  createdAt           DateTime    @default(now())

  @@unique([transactionId, authorId])
  @@index([subjectId])
}

// ── Disputes ─────────────────────────────────────────────────────────────────

enum DisputeStatus {
  open
  under_review
  resolved_buyer
  resolved_seller
  escalated
}

model Dispute {
  id            String        @id @default(uuid())
  transactionId String        @unique
  transaction   Transaction   @relation(fields: [transactionId], references: [id])
  raisedById    String
  raisedBy      User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  reason        String
  evidence      String[]
  status        DisputeStatus @default(open)
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

// ── Credits ──────────────────────────────────────────────────────────────────

enum CreditEventKind {
  registration_bonus
  share_reward
  referral
  purchase
  featured_listing
  grab_it_now
  refund
  admin_adjustment
}

model CreditEvent {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  kind      CreditEventKind
  delta     Int
  balance   Int
  note      String?
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

// ── Wishlist (saved listings) & Wish Items (wanted alerts) ─────────────────

model WishlistItem {
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([userId])
}

// WishItem = "I'm looking for X" — triggers wish_matched notification
model WishItem {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  department  Department?
  maxPrice    Decimal?  @db.Decimal(10, 2)
  keywords    String[]
  active      Boolean   @default(true)
  lastMatchAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([active])
}

model SavedSearch {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  query       Json
  alertsOn    Boolean   @default(true)
  lastAlertAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ── Following ────────────────────────────────────────────────────────────────

model Following {
  followerId  String
  followingId String
  follower    User     @relation("Follower",  fields: [followerId],  references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ── Reports ───────────────────────────────────────────────────────────────────

enum ReportReason {
  scam
  counterfeit
  prohibited
  misleading
  price_gouging
  duplicate
  contact_info_leak
  other
}

enum ReportStatus {
  open
  under_review
  actioned
  dismissed
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reporter       User         @relation("Reporter",     fields: [reporterId],    references: [id])
  reportedUserId String?
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  listingId      String?
  listing        Listing?     @relation(fields: [listingId], references: [id])
  reason         ReportReason
  notes          String?
  status         ReportStatus @default(open)
  actionTaken    String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([status])
  @@index([reportedUserId])
  @@index([listingId])
}

// ── Moderation (Exec actions) ─────────────────────────────────────────────────

enum StrikeReason {
  contact_leak
  off_platform_deal
  fake_listing
  abusive_behaviour
  payment_fraud
  other
}

model UserStrike {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  reason    StrikeReason
  note      String?
  issuedBy  String      // exec user id
  createdAt DateTime    @default(now())

  @@index([userId])
}

model ExecAuditLog {
  id           String    @id @default(uuid())
  execUserId   String
  execUser     ExecUser  @relation(fields: [execUserId], references: [id])
  targetUserId String?
  targetUser   User?     @relation("ExecTarget", fields: [targetUserId], references: [id])
  action       String    // "strike" | "suspend" | "award_credits" | "mark_verified" | "remove_listing" etc.
  detail       Json?
  createdAt    DateTime  @default(now())

  @@index([execUserId])
  @@index([targetUserId])
  @@index([createdAt(sort: Desc)])
}

// ── Jobs ─────────────────────────────────────────────────────────────────────

enum JobType {
  full_time
  part_time
  contract
  temporary
  volunteer
}

enum ApplicationStatus {
  applied
  viewed
  shortlisted
  rejected
  hired
}

model JobListing {
  id           String    @id @default(uuid())
  listingId    String    @unique
  listing      Listing   @relation(fields: [listingId], references: [id])
  employerId   String
  jobTitle     String
  company      String
  type         JobType
  salaryMin    Decimal?  @db.Decimal(10, 2)
  salaryMax    Decimal?  @db.Decimal(10, 2)
  salaryPeriod String?   // 'month' | 'year' | 'hour' — how the salary is quoted
  remote       Boolean   @default(false)
  skills       String[]
  applyUrl     String?
  expiresAt    DateTime?
  // Extended job-post details (Post a Job form)
  sector       String?   // job category e.g. Hostelería, Retail, Construction
  address      String?   // full address (also drives the listing map)
  hours        String?   // hours of operation e.g. "Mon–Fri 9:00–17:00"
  startDate    DateTime? // expected start date
  payments     Int?      // salary payments per year (e.g. 12 or 14)
  overtime     Boolean   @default(false)
  tips         Boolean   @default(false)
  // Employer-defined screening questions candidates answer on Apply.
  // Shape: [{ id, label, type: 'short'|'long'|'choice'|'boolean'|'number', required, options? }]
  applicationQuestions Json?
  createdAt    DateTime  @default(now())

  applications JobApplication[]
}

model JobApplication {
  id           String            @id @default(uuid())
  jobListingId String
  jobListing   JobListing        @relation(fields: [jobListingId], references: [id])
  applicantId  String
  applicant    User              @relation(fields: [applicantId], references: [id])
  coverNote    String?
  cvUrl        String?
  employerNote String?           // e.g. a required reason when an employer rejects
  // Structured recruitment data collected at apply time (owned platform data,
  // also shown to the employer). Prefilled from the applicant's SeekerProfile.
  fullName         String?
  email            String?
  phone            String?
  location         String?
  rightToWork      String?
  languages        String[]          @default([])
  experienceMonths Int?
  currentRole      String?
  expectedSalary   Int?
  availability     String?
  linkedinUrl      String?
  answers          Json?             // answers to the employer's screening questions
  dataConsent      Boolean           @default(false)
  // Full CV data captured at apply time — the recruiter sees what was submitted,
  // never a version the candidate edited afterwards. Rendered anonymised until
  // the application is shortlisted/hired or the candidate is unlocked, then full.
  cvSnapshot       Json?
  status       ApplicationStatus @default(applied)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([jobListingId, applicantId])
  @@index([jobListingId])
  @@index([applicantId])
}

// ── Property ─────────────────────────────────────────────────────────────────

enum PropertyType {
  sale
  rent
  holiday
  commercial
  land
  new_build
}

model PropertyListing {
  id           String       @id @default(uuid())
  listingId    String       @unique
  listing      Listing      @relation(fields: [listingId], references: [id])
  type         PropertyType
  bedrooms     Int?
  bathrooms    Int?
  m2           Decimal?     @db.Decimal(8, 2)
  community    String?
  floor        Int?
  hasPool      Boolean      @default(false)
  hasGarage    Boolean      @default(false)
  energyRating String?
  lat          Float?
  lng          Float?
  createdAt    DateTime     @default(now())
}

// ── Handy Help ────────────────────────────────────────────────────────────────

enum HandyCategory {
  plumbing
  electrical
  cleaning
  painting
  gardening
  moving
  assembly
  it_support
  tutoring
  beauty
  beauty_nails
  pet_care
  childcare
  other
}

model HandyListing {
  id                String        @id @default(uuid())
  listingId         String        @unique
  listing           Listing       @relation(fields: [listingId], references: [id])
  providerId        String
  provider          User          @relation(fields: [providerId], references: [id])
  category          HandyCategory
  pricePerHour      Decimal?      @db.Decimal(8, 2)
  priceFixed        Decimal?      @db.Decimal(8, 2)
  availableDays     Int[]         // 0=Sun..6=Sat
  responseTimeHours Int?
  insured           Boolean       @default(false)
  createdAt         DateTime      @default(now())

  @@index([category])
  @@index([providerId])
}

// ── CRM (Exec only) ──────────────────────────────────────────────────────────

enum PipelineStage {
  lead
  qualified
  pitch
  proposal
  close
  won
  nurture
}

model CrmContact {
  id         String        @id @default(uuid())
  name       String
  email      String?
  phone      String?
  company    String?
  stage      PipelineStage @default(lead)
  value      Decimal       @default(0) @db.Decimal(10, 2)
  assignedTo String?
  assignee   User?         @relation("CrmAssigned", fields: [assignedTo], references: [id])
  notes      String?
  tags       String[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([stage])
  @@index([assignedTo])
}

// ── Banners & E-shots (Exec only) ────────────────────────────────────────────

enum BannerPosition {
  home_top
  home_mid
  category
  checkout
}

model Banner {
  id        String         @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  active    Boolean        @default(false)
  position  BannerPosition
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime       @default(now())

  @@index([active])
  @@index([position])
}

enum EshotSegment {
  all
  grabber
  dealer
  trader
  pro
  business
  inactive_30
  inactive_60
  new_members
}

model Eshot {
  id          String       @id @default(uuid())
  subject     String
  bodyHtml    String
  preheader   String?      // inbox preview line
  fromName    String?      // overrides the default sender name
  segment     EshotSegment
  status      String       @default("draft") // draft | sending | sent | failed
  scheduledAt DateTime?
  sentAt      DateTime?
  // Rolled up from EshotRecipient by the Resend webhook.
  recipientCount Int       @default(0)
  deliveredCount Int       @default(0)
  bounceCount    Int       @default(0)
  complaintCount Int       @default(0)
  openCount   Int          @default(0)
  clickCount  Int          @default(0)
  createdAt   DateTime     @default(now())

  recipients  EshotRecipient[]

  @@index([sentAt])
}

// One row per person per campaign — the unit of delivery and engagement.
// resendId links a Resend email back to us when its webhook events arrive.
model EshotRecipient {
  id         String    @id @default(uuid())
  eshotId    String
  eshot      Eshot     @relation(fields: [eshotId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  email      String
  resendId   String?   @unique
  status     String    @default("queued") // queued | sent | delivered | bounced | complained | failed
  openCount  Int       @default(0)
  clickCount Int       @default(0)
  openedAt   DateTime?
  clickedAt  DateTime?
  bouncedAt  DateTime?
  error      String?
  createdAt  DateTime  @default(now())

  @@unique([eshotId, email])
  @@index([eshotId])
  @@index([userId])
}

// ── Affiliate / Referral ──────────────────────────────────────────────────────

model AffiliateLink {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  targetUrl   String
  clicks      Int       @default(0)
  conversions Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  referrals   Referral[]

  @@index([slug])
}

model Referral {
  id              String        @id @default(uuid())
  affiliateLinkId String
  affiliateLink   AffiliateLink @relation(fields: [affiliateLinkId], references: [id])
  referredEmail   String?
  registeredAt    DateTime?
  creditAwarded   Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([affiliateLinkId])
}
