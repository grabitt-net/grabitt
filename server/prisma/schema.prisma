// Grabitt v2 — Prisma Schema
// Every monetary calculation uses server-side values only.
// Never trust client-sent fee or net amounts. (§10.2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Users ──────────────────────────────────────────────────────────────────

enum UserGrade {
  grabber
  dealer
  trader
  pro
}

enum Locale {
  en
  es
  de
  da
  sv
  nl
  fr
  pt
}

model User {
  id                 String    @id @default(uuid())
  supabaseId         String    @unique
  email              String    @unique
  displayName        String
  avatar             String?
  grade              UserGrade @default(grabber)
  salesCount         Int       @default(0)
  avgRating          Float?
  credits            Int       @default(50)
  isBusiness         Boolean   @default(false)
  businessVerified   Boolean   @default(false)
  businessTrialEnds  DateTime?
  stripeAccountId    String?
  locale             Locale    @default(en)

  // Verification
  isVerified         Boolean   @default(false)
  emailVerified      Boolean   @default(false)
  phoneVerified      Boolean   @default(false)
  idVerified         Boolean   @default(false)
  addressVerified    Boolean   @default(false)

  // Moderation
  strikeCount        Int       @default(0)
  suspendedAt        DateTime?
  suspendedUntil     DateTime?
  suspendedReason    String?

  // Snowbird mode — member marks themselves away
  snowbirdMode       Boolean   @default(false)
  snowbirdUntil      DateTime?

  // Department interests used for personalisation & alerts
  interests          String[]  @default([])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  listings           Listing[]
  buyerTransactions  Transaction[]      @relation("Buyer")
  sellerTransactions Transaction[]      @relation("Seller")
  sentMessages       Message[]
  threads            ThreadParticipant[]
  notifications      Notification[]
  creditEvents       CreditEvent[]
  wishlistItems      WishlistItem[]
  wishItems          WishItem[]
  savedSearches      SavedSearch[]
  reviews            Review[]           @relation("ReviewAuthor")
  receivedReviews    Review[]           @relation("ReviewSubject")
  disputes           Dispute[]          @relation("DisputeRaiser")
  crmContacts        CrmContact[]       @relation("CrmAssigned")
  handyListings      HandyListing[]
  following          Following[]        @relation("Follower")
  followers          Following[]        @relation("Following")
  pushTokens         PushToken[]
  reportsFiled       Report[]           @relation("Reporter")
  reportsAgainst     Report[]           @relation("ReportedUser")
  jobApplications    JobApplication[]
  strikes            UserStrike[]
  execAuditLogs      ExecAuditLog[]     @relation("ExecTarget")

  @@index([grade])
  @@index([email])
}

model ExecUser {
  id           String         @id @default(uuid())
  email        String         @unique
  role         ExecRole
  createdAt    DateTime       @default(now())

  auditLogs    ExecAuditLog[]
}

enum ExecRole {
  super_admin
  admin
  support
}

// ── Listings ────────────────────────────────────────────────────────────────

enum Department {
  home_garden
  jobs
  fashion
  sport
  gaming
  electronics
  gift_ideas
  kids_baby
  property
  health_fitness
  food_store
  retro_vintage
  grab_it_now
  handy_help
  pet_shop
  motors
  services
  collectables
  other
}

enum ListingCondition {
  new
  like_new
  very_good
  good
  fair
  spares
}

enum ListingStatus {
  draft
  active
  grab_it_now
  sold
  expired
  removed
}

model Listing {
  id               String           @id @default(uuid())
  sellerId         String
  seller           User             @relation(fields: [sellerId], references: [id])
  title            String
  description      String
  price            Decimal          @db.Decimal(10, 2)
  department       Department
  condition        ListingCondition
  status           ListingStatus    @default(draft)
  images           String[]
  location         String
  lat              Float?
  lng              Float?
  isFeatured       Boolean          @default(false)
  featuredUntil    DateTime?
  grabItNowUntil   DateTime?
  grabItNowWindow  Int?
  grabItNowPrice   Decimal?         @db.Decimal(10, 2)
  deliveryFee      Decimal          @default(0) @db.Decimal(10, 2)
  deliveryMethod   DeliveryMethod?  // null = delivery not offered (collection only)
  autoAcceptMin    Decimal?         @db.Decimal(10, 2)  // offers >= this are auto-accepted (seller-only, never shown to buyers)
  viewCount        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  transaction      Transaction?
  jobListing       JobListing?
  propertyListing  PropertyListing?
  handyListing     HandyListing?
  wishlistItems    WishlistItem[]
  reports          Report[]
  offers           Offer[]

  @@index([department])
  @@index([status])
  @@index([sellerId])
  @@index([isFeatured])
  @@index([createdAt(sort: Desc)])
  @@index([location])
}

// ── Transactions ─────────────────────────────────────────────────────────────

enum TransactionStatus {
  pending_payment
  held
  confirmed_handover
  completed
  released
  disputed
  refunded
  cancelled
}

enum FulfilmentType {
  collection   // buyer collects in person — released via QR handover scan
  courier      // shipped by tracked courier — released on first waypoint scan (in transit)
  delivery     // seller delivers in person (charged) — released via QR handover scan
}

// How a seller fulfils delivery when they offer it on a listing
enum DeliveryMethod {
  courier      // tracked shipping
  in_person    // seller drops off, confirmed by QR at the door
}

model Transaction {
  id                    String            @id @default(uuid())
  listingId             String            @unique
  listing               Listing           @relation(fields: [listingId], references: [id])
  buyerId               String
  buyer                 User              @relation("Buyer", fields: [buyerId], references: [id])
  sellerId              String
  seller                User              @relation("Seller", fields: [sellerId], references: [id])
  amount                Decimal           @db.Decimal(10, 2)
  platformFee           Decimal           @db.Decimal(10, 2)
  sellerNet             Decimal           @db.Decimal(10, 2)
  status                TransactionStatus @default(pending_payment)
  quantity              Int               @default(1)
  fulfilmentType        FulfilmentType    @default(collection)
  stripePaymentIntentId String?
  stripeTransferId      String?
  handoverQrToken       String?           // signed token for QR handover confirmation
  handoverConfirmedAt   DateTime?
  trackingCarrier       String?           // courier fulfilment: carrier name/slug
  trackingNumber        String?           // courier fulfilment: tracking number
  firstScanAt           DateTime?         // courier: first waypoint scan → funds release trigger
  fundsReleasedAt       DateTime?
  autoReleaseAt         DateTime?         // 14 days after handoverConfirmedAt (§10.2)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  dispute               Dispute?
  reviews               Review[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([autoReleaseAt])
}

// ── Messaging ────────────────────────────────────────────────────────────────

enum MessageChannel {
  in_app
  sms
  whatsapp
}

model Thread {
  id            String             @id @default(uuid())
  listingId     String
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())

  participants  ThreadParticipant[]
  messages      Message[]

  @@index([listingId])
  @@index([lastMessageAt(sort: Desc)])
}

model ThreadParticipant {
  threadId String
  userId   String
  thread   Thread @relation(fields: [threadId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@id([threadId, userId])
}

model Message {
  id            String         @id @default(uuid())
  threadId      String
  thread        Thread         @relation(fields: [threadId], references: [id])
  senderId      String
  sender        User           @relation(fields: [senderId], references: [id])
  body          String
  channel       MessageChannel @default(in_app)
  blocked       Boolean        @default(false)
  blockedReason String?        // populated when contact-info regex fires (§10.2)
  readAt        DateTime?
  createdAt     DateTime       @default(now())

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}

// ── Notifications ─────────────────────────────────────────────────────────────

enum NotificationKind {
  new_message
  offer_received
  offer_accepted
  offer_declined
  payment_held
  handover_confirmed
  funds_released
  new_review
  listing_expiring
  grade_upgrade
  credits_received
  dispute_opened
  dispute_resolved
  wish_matched
  system
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  kind      NotificationKind
  title     String
  body      String
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt(sort: Desc)])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String   // "ios" | "android"
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Offers ──────────────────────────────────────────────────────────────────

enum OfferStatus {
  pending
  accepted
  declined
  countered
  expired
  withdrawn
}

model Offer {
  id        String      @id @default(uuid())
  listingId String
  listing   Listing     @relation(fields: [listingId], references: [id])
  buyerId   String
  amount    Decimal     @db.Decimal(10, 2)
  message   String?
  status    OfferStatus @default(pending)
  expiresAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

// ── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id                  String      @id @default(uuid())
  transactionId       String
  transaction         Transaction @relation(fields: [transactionId], references: [id])
  authorId            String
  author              User        @relation("ReviewAuthor", fields: [authorId], references: [id])
  subjectId           String
  subject             User        @relation("ReviewSubject", fields: [subjectId], references: [id])
  rating              Int         // overall 1–5
  accuracyRating      Int?        // item as described 1–5
  communicationRating Int?        // seller responsiveness 1–5
  speedRating         Int?        // handover speed 1–5
  comment             String?
  createdAt           DateTime    @default(now())

  @@unique([transactionId, authorId])
  @@index([subjectId])
}

// ── Disputes ─────────────────────────────────────────────────────────────────

enum DisputeStatus {
  open
  under_review
  resolved_buyer
  resolved_seller
  escalated
}

model Dispute {
  id            String        @id @default(uuid())
  transactionId String        @unique
  transaction   Transaction   @relation(fields: [transactionId], references: [id])
  raisedById    String
  raisedBy      User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  reason        String
  evidence      String[]
  status        DisputeStatus @default(open)
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

// ── Credits ──────────────────────────────────────────────────────────────────

enum CreditEventKind {
  registration_bonus
  share_reward
  referral
  purchase
  featured_listing
  grab_it_now
  refund
  admin_adjustment
}

model CreditEvent {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  kind      CreditEventKind
  delta     Int
  balance   Int
  note      String?
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

// ── Wishlist (saved listings) & Wish Items (wanted alerts) ─────────────────

model WishlistItem {
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([userId])
}

// WishItem = "I'm looking for X" — triggers wish_matched notification
model WishItem {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  department  Department?
  maxPrice    Decimal?  @db.Decimal(10, 2)
  keywords    String[]
  active      Boolean   @default(true)
  lastMatchAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([active])
}

model SavedSearch {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  query       Json
  alertsOn    Boolean   @default(true)
  lastAlertAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ── Following ────────────────────────────────────────────────────────────────

model Following {
  followerId  String
  followingId String
  follower    User     @relation("Follower",  fields: [followerId],  references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ── Reports ───────────────────────────────────────────────────────────────────

enum ReportReason {
  scam
  counterfeit
  prohibited
  misleading
  price_gouging
  duplicate
  contact_info_leak
  other
}

enum ReportStatus {
  open
  under_review
  actioned
  dismissed
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reporter       User         @relation("Reporter",     fields: [reporterId],    references: [id])
  reportedUserId String?
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  listingId      String?
  listing        Listing?     @relation(fields: [listingId], references: [id])
  reason         ReportReason
  notes          String?
  status         ReportStatus @default(open)
  actionTaken    String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([status])
  @@index([reportedUserId])
  @@index([listingId])
}

// ── Moderation (Exec actions) ─────────────────────────────────────────────────

enum StrikeReason {
  contact_leak
  off_platform_deal
  fake_listing
  abusive_behaviour
  payment_fraud
  other
}

model UserStrike {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  reason    StrikeReason
  note      String?
  issuedBy  String      // exec user id
  createdAt DateTime    @default(now())

  @@index([userId])
}

model ExecAuditLog {
  id           String    @id @default(uuid())
  execUserId   String
  execUser     ExecUser  @relation(fields: [execUserId], references: [id])
  targetUserId String?
  targetUser   User?     @relation("ExecTarget", fields: [targetUserId], references: [id])
  action       String    // "strike" | "suspend" | "award_credits" | "mark_verified" | "remove_listing" etc.
  detail       Json?
  createdAt    DateTime  @default(now())

  @@index([execUserId])
  @@index([targetUserId])
  @@index([createdAt(sort: Desc)])
}

// ── Jobs ─────────────────────────────────────────────────────────────────────

enum JobType {
  full_time
  part_time
  contract
  temporary
  volunteer
}

enum ApplicationStatus {
  applied
  viewed
  shortlisted
  rejected
  hired
}

model JobListing {
  id           String    @id @default(uuid())
  listingId    String    @unique
  listing      Listing   @relation(fields: [listingId], references: [id])
  employerId   String
  jobTitle     String
  company      String
  type         JobType
  salaryMin    Decimal?  @db.Decimal(10, 2)
  salaryMax    Decimal?  @db.Decimal(10, 2)
  remote       Boolean   @default(false)
  skills       String[]
  applyUrl     String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  applications JobApplication[]
}

model JobApplication {
  id           String            @id @default(uuid())
  jobListingId String
  jobListing   JobListing        @relation(fields: [jobListingId], references: [id])
  applicantId  String
  applicant    User              @relation(fields: [applicantId], references: [id])
  coverNote    String?
  cvUrl        String?
  status       ApplicationStatus @default(applied)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([jobListingId, applicantId])
  @@index([jobListingId])
  @@index([applicantId])
}

// ── Property ─────────────────────────────────────────────────────────────────

enum PropertyType {
  sale
  rent
  holiday
  commercial
  land
  new_build
}

model PropertyListing {
  id           String       @id @default(uuid())
  listingId    String       @unique
  listing      Listing      @relation(fields: [listingId], references: [id])
  type         PropertyType
  bedrooms     Int?
  bathrooms    Int?
  m2           Decimal?     @db.Decimal(8, 2)
  community    String?
  floor        Int?
  hasPool      Boolean      @default(false)
  hasGarage    Boolean      @default(false)
  energyRating String?
  lat          Float?
  lng          Float?
  createdAt    DateTime     @default(now())
}

// ── Handy Help ────────────────────────────────────────────────────────────────

enum HandyCategory {
  plumbing
  electrical
  cleaning
  painting
  gardening
  moving
  assembly
  it_support
  tutoring
  beauty
  beauty_nails
  pet_care
  childcare
  other
}

model HandyListing {
  id                String        @id @default(uuid())
  listingId         String        @unique
  listing           Listing       @relation(fields: [listingId], references: [id])
  providerId        String
  provider          User          @relation(fields: [providerId], references: [id])
  category          HandyCategory
  pricePerHour      Decimal?      @db.Decimal(8, 2)
  priceFixed        Decimal?      @db.Decimal(8, 2)
  availableDays     Int[]         // 0=Sun..6=Sat
  responseTimeHours Int?
  insured           Boolean       @default(false)
  createdAt         DateTime      @default(now())

  @@index([category])
  @@index([providerId])
}

// ── CRM (Exec only) ──────────────────────────────────────────────────────────

enum PipelineStage {
  lead
  qualified
  pitch
  proposal
  close
  won
  nurture
}

model CrmContact {
  id         String        @id @default(uuid())
  name       String
  email      String?
  phone      String?
  company    String?
  stage      PipelineStage @default(lead)
  value      Decimal       @default(0) @db.Decimal(10, 2)
  assignedTo String?
  assignee   User?         @relation("CrmAssigned", fields: [assignedTo], references: [id])
  notes      String?
  tags       String[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([stage])
  @@index([assignedTo])
}

// ── Banners & E-shots (Exec only) ────────────────────────────────────────────

enum BannerPosition {
  home_top
  home_mid
  category
  checkout
}

model Banner {
  id        String         @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  active    Boolean        @default(false)
  position  BannerPosition
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime       @default(now())

  @@index([active])
  @@index([position])
}

enum EshotSegment {
  all
  grabber
  dealer
  trader
  pro
  business
  inactive_30
  inactive_60
  new_members
}

model Eshot {
  id          String       @id @default(uuid())
  subject     String
  bodyHtml    String
  segment     EshotSegment
  scheduledAt DateTime?
  sentAt      DateTime?
  openCount   Int          @default(0)
  clickCount  Int          @default(0)
  createdAt   DateTime     @default(now())

  @@index([sentAt])
}

// ── Affiliate / Referral ──────────────────────────────────────────────────────

model AffiliateLink {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  targetUrl   String
  clicks      Int       @default(0)
  conversions Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  referrals   Referral[]

  @@index([slug])
}

model Referral {
  id              String        @id @default(uuid())
  affiliateLinkId String
  affiliateLink   AffiliateLink @relation(fields: [affiliateLinkId], references: [id])
  referredEmail   String?
  registeredAt    DateTime?
  creditAwarded   Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([affiliateLinkId])
}
